# Database Configuration
POSTGRES_DB=arc4ne_db
POSTGRES_USER=arc4ne_user
POSTGRES_PASSWORD=secure_password_change_this
DATABASE_URL=postgresql://arc4ne_user:secure_password_change_this@arc4ne-db:5432/arc4ne_db

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Frontend Configuration
# For local development, this can be left as localhost
# For remote access, set this to your server's IP or domain
# Example: NEXT_PUBLIC_API_URL=http://192.168.1.100/api/v1
NEXT_PUBLIC_API_URL=http://localhost/api/v1
NODE_ENV=development
